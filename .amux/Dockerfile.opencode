FROM amux-amux:latest

# Install opencode from official GitHub releases
RUN ARCH="$(dpkg --print-architecture)" && \
    case "${ARCH}" in \
        amd64) OC_ARCH="x64" ;; \
        arm64) OC_ARCH="arm64" ;; \
        *) echo "Unsupported architecture: ${ARCH}" && exit 1 ;; \
    esac && \
    curl -fsSL \
        "https://github.com/sst/opencode/releases/latest/download/opencode-linux-${OC_ARCH}.tar.gz" \
        | tar xz -C /usr/local/bin opencode && \
    chmod +x /usr/local/bin/opencode

# Create non-root user for agent operations
RUN useradd -m -s /bin/bash amux \
    && mkdir -p /workspace \
    && chown amux:amux /workspace

USER amux
WORKDIR /workspace
